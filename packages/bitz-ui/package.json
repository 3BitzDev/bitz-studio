{
  "name": "@bitz-studio/bitz-ui",
  "description": "A pure CSS component library built on DaisyUI and TailwindCSS. Framework-agnostic, themable, and ready for any web project.",
  "main": "dist/bitz-ui.css",
  "style": "dist/bitz-ui.css",
  "files": [
    "dist",
    "themes"
  ],
  "scripts": {
    "build": "npm run build:css && npm run build:minify",
    "build:css": "tailwindcss -i ./src/index.css -o ./dist/bitz-ui.css",
    "build:minify": "tailwindcss -i ./src/index.css -o ./dist/bitz-ui.min.css --minify",
    "dev": "tailwindcss -i ./src/index.css -o ./dist/bitz-ui.css --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "css",
    "ui",
    "components",
    "daisyui",
    "tailwind",
    "theme",
    "framework-agnostic"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "tailwindcss": "^4.2.2",
    "daisyui": "^5.5.19"
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.17"
  }
}
